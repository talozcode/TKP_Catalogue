# Google Sheets — service account credentials (server-only; do NOT prefix with NEXT_PUBLIC_).
# Create the service account in Google Cloud Console → IAM → Service Accounts,
# generate a JSON key, then share the spreadsheet with this email (Editor).

GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private_key value from the JSON key file. Keep the literal "\n"
# escapes — the server converts them to real newlines at runtime.
GOOGLE_PRIVATE_KEY=
# The spreadsheet ID — the long token between /d/ and /edit in the sheet URL.
GOOGLE_SHEET_ID=
