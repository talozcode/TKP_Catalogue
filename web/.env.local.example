# The deployed Apps Script Web App URL (Deploy → New deployment → Web app).
# Format: https://script.google.com/macros/s/AKfycb.../exec
NEXT_PUBLIC_APPS_SCRIPT_URL=

# Shared token. Must match the API_TOKEN script property in Apps Script.
# Use a long random string. This is sent in the request body.
NEXT_PUBLIC_API_TOKEN=
